{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Job",
  "type": "object",
  "properties": {
    "jobId": { "type": "string" },
    "status": { "type": "string", "enum": ["pending", "running", "completed", "failed"] },
    "createdAt": { "type": "string", "format": "date-time" }
  },
  "required": ["jobId", "status", "createdAt"]
}